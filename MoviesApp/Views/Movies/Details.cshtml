@model MoviesApp.ViewModels.MovieDetailsViewModel

<div class="d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card shadow-lg p-4 text-center movie-details-container" style="max-width: 700px; width: 100%;">
        <h2 class="mb-3" style="color: #ff4444; font-weight: 700;">@Model.Movie.Title @if(Model.Movie.Year.HasValue){<span>(@Model.Movie.Year)</span>}</h2>

        <img src="@(!string.IsNullOrEmpty(Model.Movie.PosterUrl) ? Model.Movie.PosterUrl : Url.Content("~/images/placeholder.png"))"
             class="img-fluid rounded mb-3 mx-auto" alt="@Model.Movie.Title" style="max-width: 100%; max-height: 400px; object-fit: cover; box-shadow: 0 4px 10px rgba(0,0,0,0.5);" />

        <div class="text-start" style="color: #e0e0e0;">
            @if(!string.IsNullOrEmpty(Model.Movie.Genre))
            {
                <p><strong>Жанр:</strong> <span style="color: #ff6666;">@Model.Movie.Genre</span></p>
            }

            @if(!string.IsNullOrEmpty(Model.Movie.Plot))
            {
                <p><strong>Краток опис:</strong> <span style="color: #ff6666;">@Model.Movie.Plot</span></p>
            }
        </div>
        
        <div class="mt-3 d-flex flex-column gap-2 align-items-center">
            @if(User.Identity!.IsAuthenticated)
            {
                <a class="btn btn-warning btn-lg" asp-controller="Movies" asp-action="Edit" asp-route-id="@Model.Movie.Id">Уреди</a>
                <a class="btn btn-danger btn-lg" asp-controller="Movies" asp-action="Delete" asp-route-id="@Model.Movie.Id">Избриши</a>
            }
            <a class="btn btn-secondary btn-lg" asp-controller="Movies" asp-action="Index">Назад кон листата</a>
        </div>
    </div>
</div>