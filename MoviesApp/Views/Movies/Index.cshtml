@model MoviesApp.ViewModels.MovieIndexViewModel

<h2 class="text-center mb-4 display-5" style="color: #ff4444; font-weight: 700;">Сите филмови</h2>

<form asp-action="Index" method="get" class="mb-4 d-flex justify-content-center gap-2 flex-wrap">
    <input type="text" name="searchTerm" value="@Model.SearchString" placeholder="Пребарај по наслов..." class="form-control form-control-lg" style="max-width:700px;" />
    <select name="genreFilter" class="form-select form-select-lg" style="max-width:700px;" asp-items="Model.AvailableGenres"></select>
    <button type="submit" class="btn btn-secondary btn-lg">Пребарај</button>
</form>

<div class="d-flex justify-content-end mb-3">
    <a asp-action="Create" class="btn btn-primary">+ Додај филм</a>
</div>

<div class="movie-grid">
    @foreach (var movie in Model.Movies)
    {
        <div class="movie-card">
            <img src="@movie.PosterUrl" alt="@movie.Title Poster" class="card-img-top" />
            <div class="card-body">
                <h5 class="card-title">@movie.Title (@movie.Year)</h5>
                <p class="card-text">@movie.Plot</p>
                <div class="d-flex justify-content-between">
                    <a asp-action="Details" asp-route-id="@movie.Id" class="btn btn-info">Детали</a>
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <a asp-action="Edit" asp-route-id="@movie.Id" class="btn btn-warning">Уреди</a>
                        <a asp-action="Delete" asp-route-id="@movie.Id" class="btn btn-danger">Избриши</a>
                    }
                </div>
            </div>
        </div>
    }
</div>